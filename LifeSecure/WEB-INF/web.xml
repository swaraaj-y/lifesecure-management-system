<?xml version="1.0" encoding="UTF-8"?>

<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
         http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

    <!-- ================= WELCOME FILE ================= -->
    <welcome-file-list>
        <welcome-file>index.html</welcome-file>
    </welcome-file-list>

    <!-- ================= CUSTOMER REGISTER ================= -->
    <servlet>
        <servlet-name>CustomerRegister</servlet-name>
        <servlet-class>com.lifesecure.servlet.CustomerRegisterServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>CustomerRegister</servlet-name>
        <url-pattern>/register</url-pattern>
    </servlet-mapping>

    <!-- ================= CUSTOMER LOGIN ================= -->
    <servlet>
        <servlet-name>CustomerLogin</servlet-name>
        <servlet-class>com.lifesecure.servlet.CustomerLoginServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>CustomerLogin</servlet-name>
        <url-pattern>/login</url-pattern>
    </servlet-mapping>

    <!-- ================= LOGOUT ================= -->
    <servlet>
        <servlet-name>Logout</servlet-name>
        <servlet-class>com.lifesecure.servlet.LogoutServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>Logout</servlet-name>
        <url-pattern>/logout</url-pattern>
    </servlet-mapping>

    <!-- ================= APPLY POLICY ================= -->
    <servlet>
        <servlet-name>ApplyPolicy</servlet-name>
        <servlet-class>com.lifesecure.servlet.ApplyPolicyServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ApplyPolicy</servlet-name>
        <url-pattern>/applyPolicy</url-pattern>
    </servlet-mapping>

    <!-- ================= VIEW POLICIES ================= -->
    <servlet>
        <servlet-name>ViewPolicies</servlet-name>
        <servlet-class>com.lifesecure.servlet.ViewPoliciesServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ViewPolicies</servlet-name>
        <url-pattern>/viewPolicies</url-pattern>
    </servlet-mapping>

    <!-- ================= VIEW PROFILE ================= -->
    <servlet>
        <servlet-name>ViewProfile</servlet-name>
        <servlet-class>com.lifesecure.servlet.ViewProfileServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ViewProfile</servlet-name>
        <url-pattern>/viewProfile</url-pattern>
    </servlet-mapping>

    <!-- ================= EDIT PROFILE ================= -->
    <servlet>
        <servlet-name>EditProfile</servlet-name>
        <servlet-class>com.lifesecure.servlet.EditProfileServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>EditProfile</servlet-name>
        <url-pattern>/editProfile</url-pattern>
    </servlet-mapping>

    <!-- ================= UPDATE PROFILE ================= -->
    <servlet>
        <servlet-name>UpdateProfile</servlet-name>
        <servlet-class>com.lifesecure.servlet.UpdateProfileServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>UpdateProfile</servlet-name>
        <url-pattern>/updateProfile</url-pattern>
    </servlet-mapping>

    <!-- ================= PAYMENT ================= -->
    <servlet>
        <servlet-name>Payment</servlet-name>
        <servlet-class>com.lifesecure.servlet.PaymentServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>Payment</servlet-name>
        <url-pattern>/pay</url-pattern>
    </servlet-mapping>

    <!-- ================= PAYMENT HISTORY ================= -->
    <servlet>
        <servlet-name>PaymentHistory</servlet-name>
        <servlet-class>com.lifesecure.servlet.PaymentHistoryServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>PaymentHistory</servlet-name>
        <url-pattern>/paymentHistory</url-pattern>
    </servlet-mapping>

    <!-- ================= AGENT REGISTER ================= -->
    <servlet>
        <servlet-name>AgentRegister</servlet-name>
        <servlet-class>com.lifesecure.servlet.AgentRegisterServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AgentRegister</servlet-name>
        <url-pattern>/agentRegister</url-pattern>
    </servlet-mapping>

    <!-- ================= AGENT LOGIN ================= -->
    <servlet>
        <servlet-name>AgentLogin</servlet-name>
        <servlet-class>com.lifesecure.servlet.AgentLoginServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AgentLogin</servlet-name>
        <url-pattern>/agentLogin</url-pattern>
    </servlet-mapping>

    <!-- ================= UPDATE POLICY STATUS ================= -->
    <servlet>
        <servlet-name>UpdatePolicyStatus</servlet-name>
        <servlet-class>com.lifesecure.servlet.UpdatePolicyStatusServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>UpdatePolicyStatus</servlet-name>
        <url-pattern>/updatePolicyStatus</url-pattern>
    </servlet-mapping>

    <!-- ================= AGENT DASHBOARD ================= -->
    <servlet>
        <servlet-name>AgentDashboard</servlet-name>
        <servlet-class>com.lifesecure.servlet.AgentDashboardServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AgentDashboard</servlet-name>
        <url-pattern>/agentDashboard</url-pattern>
    </servlet-mapping>

    <!-- ================= ADMIN LOGIN ================= -->
    <servlet>
        <servlet-name>AdminLogin</servlet-name>
        <servlet-class>com.lifesecure.servlet.AdminLoginServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AdminLogin</servlet-name>
        <url-pattern>/adminLogin</url-pattern>
    </servlet-mapping>

    <!-- ================= ADMIN DASHBOARD ================= -->
    <servlet>
        <servlet-name>AdminDashboard</servlet-name>
        <servlet-class>com.lifesecure.servlet.AdminDashboardServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AdminDashboard</servlet-name>
        <url-pattern>/adminDashboard</url-pattern>
    </servlet-mapping>

    <!-- ================= ADMIN UPDATE POLICY ================= -->
    <servlet>
        <servlet-name>AdminUpdatePolicy</servlet-name>
        <servlet-class>com.lifesecure.servlet.AdminUpdatePolicyServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AdminUpdatePolicy</servlet-name>
        <url-pattern>/adminUpdatePolicy</url-pattern>
    </servlet-mapping>

<servlet>
    <servlet-name>AgentSendApprovalServlet</servlet-name>
    <servlet-class>com.lifesecure.servlet.AgentSendApprovalServlet</servlet-class>
</servlet>

<servlet-mapping>
    <servlet-name>AgentSendApprovalServlet</servlet-name>
    <url-pattern>/agentSendApproval</url-pattern>
</servlet-mapping>

<servlet>
    <servlet-name>SubmitSupport</servlet-name>
    <servlet-class>com.lifesecure.servlet.SubmitSupportServlet</servlet-class>
</servlet>
<servlet-mapping>
    <servlet-name>SubmitSupport</servlet-name>
    <url-pattern>/submitSupport</url-pattern>
</servlet-mapping>

</web-app>
