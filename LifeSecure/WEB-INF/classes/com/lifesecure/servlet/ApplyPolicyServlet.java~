package com.lifesecure.servlet;

import com.lifesecure.util.DBConnection;
import java.io.*;
import javax.servlet.*;
import javax.servlet.http.*;
import java.sql.*;

public class ApplyPolicyServlet extends HttpServlet {

    protected void doPost(HttpServletRequest request, HttpServletResponse response)
            throws ServletException, IOException {

        HttpSession session = request.getSession(false);

        if (session == null || session.getAttribute("customerId") == null) {
            response.sendRedirect("customer-login.html");
            return;
        }

        int customerId = (int) session.getAttribute("customerId");
        String policyType = request.getParameter("policyType");
        String premium = request.getParameter("premium");
        String details = request.getParameter("details"); // optional policy details

        try (Connection conn = DBConnection.getConnection()) {

            String sql = "INSERT INTO policies(customer_id, policy_type, premium, status, agent_id, details) " +
                         "VALUES (?, ?, ?, ?, ?, ?)";

            PreparedStatement ps = conn.prepareStatement(sql);
            ps.setInt(1, customerId);
            ps.setString(2, policyType);
            ps.setString(3, premium);
            ps.setString(4, "Pending"); // initial status
            ps.setInt(5, 1); // default agent, e.g., id=1
            ps.setString(6, details);

            ps.executeUpdate();

        } catch (Exception e) {
            e.printStackTrace();
        }

        // Show confirmation page to customer
        response.setContentType("text/html");
        PrintWriter out = response.getWriter();

        out.println("<!DOCTYPE html><html><head><title>Request Submitted</title>");
        out.println("<style>");
        out.println("body { font-family: 'Segoe UI', sans-serif; text-align:center; padding-top:100px; background:#f0f4f8; }");
        out.println("h2 { color:#10b981; font-size:2rem; }");
        out.println("p { margin-top:20px; font-size:1.1rem; }");
        out.println("a { display:inline-block; margin-top:30px; padding:12px 24px; background:#3b82f6; color:white; text-decoration:none; border-radius:8px; font-weight:600; transition:0.3s; }");
        out.println("a:hover { background:#2563eb; }");
        out.println("</style></head><body>");
        out.println("<h2>✅ Policy Request Submitted!</h2>");
        out.println("<p>Your policy application has been successfully sent to our agent for review.</p>");
        out.println("<a href='customer-dashboard.html'>Go to Dashboard</a>");
        out.println("</body></html>");
    }
}
